@model ERPManagementSystem.Models.Student
@{
    Layout = "~/Views/Shared/Principal.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background-color: #020617 !important;
        color: #f1f5f9 !important;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }


    .form-card {
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        max-width: 1000px;
        margin: auto;
        overflow: hidden;
    }

    .form-header {
        background: rgba(255, 255, 255, 0.02);
        padding: 25px 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #22c55e, #10b981);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: white;
    }

    label {
        font-size: 13px;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: block;
    }

    /* 🔥 Perfect Alignment: Same height for TextBox & Select */
    .form-control, .form-select {
        background: rgba(2, 6, 23, 0.6) !important;
        border: 1px solid #334155 !important;
        color: #f1f5f9 !important;
        border-radius: 12px;
        height: 50px;
        padding: 10px 16px;
        font-size: 14px;
        transition: all 0.2s ease;
    }

    textarea.form-control {
        height: auto !important;
    }

    .form-control:focus, .form-select:focus {
        border-color: #22c55e !important;
        box-shadow: 0 0 0 4px rgba(34, 197, 94, 0.15) !important;
        background: rgba(2, 6, 23, 0.8) !important;
    }

    .btn-save {
        background: linear-gradient(135deg, #22c55e, #10b981);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 35px;
        font-weight: 700;
        transition: 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 15px rgba(34, 197, 94, 0.3);
        }
</style>

<div class="container container-main">

    @if (TempData["Success"] != null || TempData["Error"] != null)
    {
        <div class="alert @(TempData["Success"] != null ? "alert-success" : "alert-danger") bg-opacity-10 border-opacity-20 d-flex align-items-center mx-auto mb-4" style="max-width:1000px; border-radius:15px;">
            <i class="fa-solid @(TempData["Success"] != null ? "fa-circle-check" : "fa-triangle-exclamation") me-2"></i>
            @((TempData["Success"] ?? TempData["Error"]).ToString())
        </div>
    }

    <div class="card form-card">
        <div class="form-header">
            <div class="header-icon"><i class="fa fa-user-graduate"></i></div>
            <div class="text-white-50">
                <h4 class="m-0 fw-bold">Student Entry</h4>
                <small class="text-muted text-white-50">Register a new student into the ERP system</small>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">
            @using (Html.BeginForm())
            {
                <div class="row g-4">
                    <div class="col-md-6">
                        <label>Enrollment No</label>
                        @Html.TextBoxFor(x => x.EnrollmentNo, new { @class = "form-control", placeholder = "ERP-101", required = "required" })
                    </div>
                    <div class="col-md-6">
                        <label>Admission Date</label>
                        @Html.TextBoxFor(x => x.AdmissionDate, new { @class = "form-control", type = "date", required = "required" })
                    </div>

                    <div class="col-md-6">
                        <label>Post</label>
                        @Html.DropDownListFor(x => x.PostId, ViewBag.PostList as IEnumerable<SelectListItem>, "Select Post", new { @class = "form-select", required = "required" })
                    </div>
                    <div class="col-md-6">
                        <label>Course</label>
                        @Html.DropDownListFor(x => x.CourseId, ViewBag.CourseList as IEnumerable<SelectListItem>, "Select Course", new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-md-6">
                        <label>Class</label>
                        @Html.DropDownListFor(x => x.ClassId, ViewBag.ClassList as IEnumerable<SelectListItem>, "Select Class", new { @class = "form-select", required = "required" })
                    </div>
                    <div class="col-md-6">
                        <label>Academic Year</label>
                        @Html.DropDownListFor(x => x.YearOfStudent, new List<SelectListItem>
                        {
                            new SelectListItem{ Text="1st Year", Value="1"},
                            new SelectListItem{ Text="2nd Year", Value="2"},
                            new SelectListItem{ Text="3rd Year", Value="3"},
                            new SelectListItem{ Text="4th Year", Value="4"}
                        }, "Select Year", new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-md-6">
                        <label>Semester</label>
                        @Html.DropDownListFor(x => x.Semester, new List<SelectListItem>
                        {
                            new SelectListItem{ Text="Semester 1", Value="1"}, new SelectListItem{ Text="Semester 2", Value="2"},
                            new SelectListItem{ Text="Semester 3", Value="3"}, new SelectListItem{ Text="Semester 4", Value="4"},
                            new SelectListItem{ Text="Semester 5", Value="5"}, new SelectListItem{ Text="Semester 6", Value="6"},
                            new SelectListItem{ Text="Semester 7", Value="7"}, new SelectListItem{ Text="Semester 8", Value="8"}
                        }, "Select Semester", new { @class = "form-select", required = "required" })
                    </div>
                    <div class="col-md-6">
                        <label>First Name</label>
                        @Html.TextBoxFor(x => x.FirstName, new { @class = "form-control", placeholder = "Enter First Name", required = "required" })
                    </div>

                    <div class="col-md-6">
                        <label>Last Name</label>
                        @Html.TextBoxFor(x => x.LastName, new { @class = "form-control", placeholder = "Enter Last Name" })
                    </div>
                    <div class="col-md-6">
                        <label>Mobile Number</label>
                        @Html.TextBoxFor(x => x.Mobile, new { @class = "form-control", maxlength = "10", placeholder = "10 Digit Mobile No" })
                    </div>

                    <div class="col-md-6">
                        <label>Email Address</label>
                        @Html.TextBoxFor(x => x.Email, new { @class = "form-control", type = "email", placeholder = "student@example.com" })
                    </div>
                    <div class="col-md-6">
                        <label>Father's Name</label>
                        @Html.TextBoxFor(x => x.FatherName, new { @class = "form-control", placeholder = "Father's Full Name" })
                    </div>

                    <div class="col-md-12">
                        <label>Permanent Address</label>
                        @Html.TextAreaFor(x => x.Address, new { @class = "form-control", rows = "2", placeholder = "Enter full residential address" })
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top border-white border-opacity-10">
                    <button type="reset" class="btn btn-outline-secondary border-0 text-white-50">Reset</button>
                    <button type="submit" class="btn btn-save">
                        <i class="fa fa-save me-2"></i> Save Student Data
                    </button>
                </div>
            }
        </div>
    </div>
</div>