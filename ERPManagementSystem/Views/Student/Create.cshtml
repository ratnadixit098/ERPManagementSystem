@model ERPManagementSystem.Models.Student
@{
    Layout = "~/Views/Shared/Principal.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background-color: #020617 !important;
        color: #f1f5f9 !important;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    .form-card {
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        max-width: 1000px;
        margin: auto;
        overflow: hidden;
    }

    /* Error Message Styling */
    .error-msg {
        color: #ff4d4d !important;
        font-size: 12px;
        font-weight: 500;
        margin-top: 5px;
        display: block;
    }

    input.error, select.error, textarea.error {
        border: 1px solid #334155 !important;
        background: rgba(2, 6, 23, 0.6) !important;
    }

    .form-header {
        background: rgba(255, 255, 255, 0.02);
        padding: 25px 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #22c55e, #10b981);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: white;
    }

    label {
        font-size: 13px;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: block;
    }

    .form-control, .form-select {
        background: rgba(2, 6, 23, 0.6) !important;
        border: 1px solid #334155 !important;
        color: #f1f5f9 !important;
        border-radius: 12px;
        height: 50px;
        padding: 10px 16px;
        font-size: 14px;
    }

    .btn-save {
        background: linear-gradient(135deg, #22c55e, #10b981);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 35px;
        font-weight: 700;
        transition: 0.3s;
        cursor: pointer;
    }
</style>

<div class="container container-main py-5">

    @* --- SUCCESS / ERROR MESSAGE SECTION --- *@
    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success bg-success bg-opacity-10 text-success border-success border-opacity-25 alert-dismissible fade show mx-auto mb-4" style="max-width:1000px; border-radius:15px;" role="alert">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger bg-danger bg-opacity-10 text-danger border-danger border-opacity-25 alert-dismissible fade show mx-auto mb-4" style="max-width:1000px; border-radius:15px;" role="alert">
            <i class="fa-solid fa-triangle-exclamation me-2"></i> @TempData["Error"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card form-card">
        <div class="form-header">
            <div class="header-icon"><i class="fa fa-user-graduate"></i></div>
            <div>
                <h4 class="m-0 fw-bold text-white">Student Entry</h4>
                <small class="text-white-50 text-danger" style="color:red!important">Please fill all fields to save data</small>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">
            @using (Html.BeginForm("Create", "Student", FormMethod.Post, new { id = "studentForm" }))
            {
                @Html.AntiForgeryToken()
                <div class="row g-4">
                    @* Input Fields *@
                    <div class="col-md-6">
                        <label>Enrollment No</label>
                        @Html.TextBoxFor(x => x.EnrollmentNo, new { @class = "form-control", placeholder = "ERP-101" })
                    </div>

                    <div class="col-md-6">
                        <label>Admission Date</label>
                        @Html.TextBoxFor(x => x.AdmissionDate, new { @class = "form-control", type = "date" })
                    </div>

                    <div class="col-md-6">
                        <label>Post</label>
                        @Html.DropDownListFor(x => x.PostId, ViewBag.PostList as IEnumerable<SelectListItem>, "Select Post", new { @class = "form-select" })
                    </div>

                    <div class="col-md-6">
                        <label>Course</label>
                        @Html.DropDownListFor(x => x.CourseId, ViewBag.CourseList as IEnumerable<SelectListItem>, "Select Course", new { @class = "form-select" })
                    </div>

                    <div class="col-md-6">
                        <label>Class</label>
                        @Html.DropDownListFor(x => x.ClassId, ViewBag.ClassList as IEnumerable<SelectListItem>, "Select Class", new { @class = "form-select" })
                    </div>

                    <div class="col-md-6">
                        <label>Academic Year</label>
                        @Html.DropDownListFor(x => x.YearOfStudent, new List<SelectListItem>
                        {
                            new SelectListItem{ Text="1st Year", Value="1"},
                            new SelectListItem{ Text="2nd Year", Value="2"},
                            new SelectListItem{ Text="3rd Year", Value="3"},
                            new SelectListItem{ Text="4th Year", Value="4"}
                        }, "Select Year", new { @class = "form-select" })
                    </div>

                    <div class="col-md-6">
                        <label>Semester</label>
                        @Html.DropDownListFor(x => x.Semester, new List<SelectListItem>
                        {
                            new SelectListItem{ Text="Semester 1", Value="1"}, new SelectListItem{ Text="Semester 2", Value="2"},
                            new SelectListItem{ Text="Semester 3", Value="3"}, new SelectListItem{ Text="Semester 4", Value="4"},
                            new SelectListItem{ Text="Semester 5", Value="5"}, new SelectListItem{ Text="Semester 6", Value="6"},
                            new SelectListItem{ Text="Semester 7", Value="7"}, new SelectListItem{ Text="Semester 8", Value="8"}
                        }, "Select Semester", new { @class = "form-select" })
                    </div>

                    <div class="col-md-6">
                        <label>First Name</label>
                        @Html.TextBoxFor(x => x.FirstName, new { @class = "form-control", placeholder = "First Name" })
                    </div>

                    <div class="col-md-6">
                        <label>Last Name</label>
                        @Html.TextBoxFor(x => x.LastName, new { @class = "form-control", placeholder = "Last Name" })
                    </div>

                    <div class="col-md-6">
                        <label>Mobile Number</label>
                        @Html.TextBoxFor(x => x.Mobile, new { @class = "form-control", maxlength = "10", placeholder = "10 Digit Mobile No" })
                    </div>

                    <div class="col-md-6">
                        <label>Email Address</label>
                        @Html.TextBoxFor(x => x.Email, new { @class = "form-control", placeholder = "student@example.com" })
                    </div>

                    <div class="col-md-6">
                        <label>Father's Name</label>
                        @Html.TextBoxFor(x => x.FatherName, new { @class = "form-control", placeholder = "Father's Full Name" })
                    </div>

                    <div class="col-md-12">
                        <label>Permanent Address</label>
                        @Html.TextAreaFor(x => x.Address, new { @class = "form-control", rows = "2", placeholder = "Full Address" })
                    </div>
                </div>

                <div class="d-flex justify-content-end gap-3 mt-5 pt-4 border-top border-white border-opacity-10">
                    <button type="reset" class="btn btn-outline-secondary border-0 text-white-50">Reset</button>
                    <button type="submit" class="btn btn-save">Save Student Data</button>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.6.0/jquery.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>

<script>
    $(document).ready(function () {
        // Validation Rules
        $("#studentForm").validate({
            rules: {
                EnrollmentNo: "required",
                AdmissionDate: "required",
                PostId: "required",
                CourseId: "required",
                ClassId: "required",
                YearOfStudent: "required",
                Semester: "required",
                FirstName: { required: true, minlength: 2 },
                LastName: "required",
                Mobile: { required: true, digits: true, minlength: 10, maxlength: 10 },
                Email: { required: true, email: true },
                FatherName: "required",
                Address: "required"
            },
            messages: {
                EnrollmentNo: "Required",
                FirstName: "Enter valid first name",
                Mobile: "Enter 10 digit number",
                Email: "Enter valid email",
                Address: "Address is required"
            },
            errorElement: "span",
            errorClass: "error-msg"
        });
    });
</script>