@model ERPManagementSystem.Models.FeesStructure

@{
    Layout = "~/Views/Shared/Principal.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    /* ✨ Modern Dark Theme Logic */
    body {
        background-color: #020617 !important;
        color: #f1f5f9 !important;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* 💎 Glassmorphism Card */
    .form-card {
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        max-width: 650px;
        margin: auto;
        overflow: hidden;
    }

    /* 🎨 Header with Neon Gradient */
    .form-header {
        background: rgba(255, 255, 255, 0.02);
        padding: 25px 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #3b82f6, #8b5cf6);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: white;
        box-shadow: 0 0 15px rgba(59, 130, 246, 0.4);
    }

    .form-header h4 {
        margin: 0;
        font-weight: 700;
        background: linear-gradient(to right, #fff, #94a3b8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ⚡ Form Elements */
    label {
        font-size: 14px;
        font-weight: 500;
        color: #94a3b8;
        margin-bottom: 8px;
        display: block;
    }

    .form-control, .form-select {
        background: rgba(2, 6, 23, 0.6) !important;
        border: 1px solid #334155 !important;
        color: #f1f5f9 !important;
        border-radius: 12px;
        padding: 12px 16px;
        height: auto;
        transition: all 0.2s;
    }

        .form-control:focus, .form-select:focus {
            border-color: #3b82f6 !important;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.15) !important;
            outline: none;
        }

    /* 🚀 Action Button */
    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px 24px;
        font-weight: 600;
        width: 100%;
        margin-top: 10px;
        transition: all 0.3s;
        box-shadow: 0 10px 15px -3px rgba(16, 185, 129, 0.3);
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(16, 185, 129, 0.4);
            filter: brightness(1.1);
        }

    /* ✅ Success Alert */
    .alert-modern {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #34d399;
        border-radius: 12px;
        padding: 15px;
        margin-bottom: 20px;
        font-weight: 500;
    }

    .input-group-text {
        background: #1e293b !important;
        border: 1px solid #334155 !important;
        color: #94a3b8 !important;
        border-radius: 12px 0 0 12px !important;
    }

    .has-icon .form-control {
        border-radius: 0 12px 12px 0 !important;
    }
</style>

<div class="container container-main">
    <div class="card form-card">
        <div class="form-header">
            <div class="header-icon">
                <i class="fa fa-money-bill-transfer"></i>
            </div>
            <div>
                <h4>Fees Structure Entry</h4>
                <small class="text-muted">Define course-wise financial structure</small>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-modern d-flex align-items-center">
                    <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
                </div>
            }

            @using (Html.BeginForm())
            {
                <div class="mb-4">
                    <label><i class="fa fa-book-bookmark me-2 text-primary"></i>Target Course</label>
                    @Html.DropDownListFor(x => x.CourseId,
                    ViewBag.CourseList as IEnumerable<SelectListItem>,
                    "Select Course",
                    new { @class = "form-select", required = "required" })
                </div>

                <div class="row mb-4">
                    <div class="col-md-6">
                        <label><i class="fa fa-layer-group me-2 text-primary"></i>Semester / Year</label>
                        <div class="input-group has-icon">
                            <span class="input-group-text"><i class="fa fa-hashtag"></i></span>
                            @Html.TextBoxFor(x => x.Semester,
                            new { @class = "form-control", type = "number", required = "required", placeholder = "e.g. 1" })
                        </div>
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-indian-rupee-sign me-2 text-primary"></i>Total Fees</label>
                        <div class="input-group has-icon">
                            <span class="input-group-text">₹</span>
                            @Html.TextBoxFor(x => x.TotalFees,
                            new { @class = "form-control", type = "number", step = "0.01", required = "required", placeholder = "0.00" })
                        </div>
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-save">
                        <i class="fa fa-cloud-arrow-up me-2"></i> Confirm & Save Structure
                    </button>
                </div>

                <div class="text-center mt-4">
                    <a href="#" class="text-muted text-decoration-none small hover-white">
                        <i class="fa fa-arrow-left me-1"></i> Back to List
                    </a>
                </div>
            }

        </div>
    </div>
</div>