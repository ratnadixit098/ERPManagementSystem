@model ERPManagementSystem.Models.Course

@{
    Layout = "~/Views/Shared/Principal.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    /* ✨ Core Theme Reset */
    body {
        background-color: #020617 !important;
        color: #f1f5f9 !important;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* 💎 Glassmorphism Card */
    .form-card {
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        max-width: 850px;
        margin: auto;
        overflow: hidden;
    }

    /* 🎨 Header with Amber Gradient (Course Theme) */
    .form-header {
        background: rgba(255, 255, 255, 0.02);
        padding: 25px 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #f59e0b, #d97706);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        color: white;
        box-shadow: 0 0 15px rgba(245, 158, 11, 0.4);
    }

    .form-header h4 {
        margin: 0;
        font-weight: 700;
        background: linear-gradient(to right, #fff, #94a3b8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ⚡ Form Elements */
    label {
        font-size: 13px;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control, .form-select {
        background: rgba(2, 6, 23, 0.6) !important;
        border: 1px solid #334155 !important;
        color: #f1f5f9 !important;
        border-radius: 12px;
        padding: 12px 16px;
        transition: all 0.2s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #f59e0b !important;
            box-shadow: 0 0 0 4px rgba(245, 158, 11, 0.15) !important;
            background: rgba(2, 6, 23, 0.8) !important;
        }

    /* 🚀 Action Button */
    .btn-save {
        background: linear-gradient(135deg, #f59e0b, #d97706);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 12px 28px;
        font-weight: 600;
        transition: 0.3s;
        box-shadow: 0 10px 15px -3px rgba(217, 119, 6, 0.3);
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(217, 119, 6, 0.4);
            filter: brightness(1.1);
        }

    /* ✅ Success Alert */
    .alert-modern {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #34d399;
        border-radius: 16px;
        padding: 15px 25px;
        margin-bottom: 25px;
    }
</style>

<div class="container container-main">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-modern d-flex align-items-center mx-auto" style="max-width:850px;">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="card form-card">
        <div class="form-header">
            <div class="header-icon">
                <i class="fa fa-book"></i>
            </div>
            <div>
                <h4>Course Entry</h4>
                <small class="text-muted">Create and manage academic programs</small>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">
            @using (Html.BeginForm())
            {
                <div class="row g-4">

                    <div class="col-sm-6">
                        <label><i class="fa fa-sitemap me-2 text-warning"></i>Department</label>
                        @Html.DropDownListFor(x => x.DepartmentId,
                            ViewBag.DepartmentList as IEnumerable<SelectListItem>,
                            "Select Department",
                            new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-sm-6">
                        <label><i class="fa fa-hashtag me-2 text-warning"></i>Course Code</label>
                        @Html.TextBoxFor(x => x.CourseCode, new { @class = "form-control", required = "required", placeholder = "e.g. BTECH-CS" })
                    </div>

                    <div class="col-sm-12">
                        <label><i class="fa fa-graduation-cap me-2 text-warning"></i>Full Course Name</label>
                        @Html.TextBoxFor(x => x.CourseName, new { @class = "form-control", required = "required", placeholder = "e.g. Bachelor of Technology (Computer Science)" })
                    </div>

                    <div class="col-sm-6">
                        <label><i class="fa fa-calendar-days me-2 text-warning"></i>Duration (Years)</label>
                        @Html.TextBoxFor(x => x.DurationYears, new { @class = "form-control", type = "number", required = "required", placeholder = "e.g. 4" })
                    </div>

                    <div class="col-sm-6">
                        <label><i class="fa fa-list-ol me-2 text-warning"></i>Total Semesters</label>
                        @Html.TextBoxFor(x => x.TotalSemester, new { @class = "form-control", type = "number", required = "required", placeholder = "e.g. 8" })
                    </div>

                </div>

                <div class="d-flex justify-content-end gap-3 mt-5">
                    <button type="reset" class="btn btn-outline-secondary border-0 text-white-50 px-4">Discard</button>
                    <button type="submit" class="btn btn-save">
                        <i class="fa fa-save me-2"></i> Save Course Details
                    </button>
                </div>
            }
        </div>
    </div>
</div>