@model List<ERPManagementSystem.Models.TeacherDashboard>
@{
    Layout = "~/Views/Shared/TeacherLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        background: #0b0f19;
        color: #fff;
        font-family: Segoe UI;
    }

    .dashboard-card {
        background: rgba(17,24,39,.6);
        border-radius: 12px;
        padding: 18px;
        border: 1px solid rgba(255,255,255,.05);
        backdrop-filter: blur(6px);
        height: 105px;
        display: flex;
        align-items: center;
        position: relative;
        color: white;
        cursor: pointer;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg,#3b82f6,#22c55e,#f59e0b,#ef4444);
            border-radius: 12px 12px 0 0;
        }

    .card-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .card-icon {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .blue {
        background: rgba(59,130,246,.15);
        color: #3b82f6;
    }

    .green {
        background: rgba(34,197,94,.15);
        color: #22c55e;
    }

    .orange {
        background: rgba(245,158,11,.15);
        color: #f59e0b;
    }

    .red {
        background: rgba(239,68,68,.15);
        color: #ef4444;
    }

    .main-card {
        background: rgba(17,24,39,.6);
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.05);
        backdrop-filter: blur(6px);
        height: 420px;
        display: flex;
        flex-direction: column;
    }

    .table-wrapper {
        overflow-y: auto;
        flex: 1;
    }

    .table thead th {
        position: sticky;
        top: 0;
        background: #111827 !important;
        z-index: 10;
    }

    .chart-container {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
    }
</style>

<div class="container-fluid mt-3">

    <div class="row mb-3">

        <div class="col-md-3">
            <div class="dashboard-card" onclick="filterTable('all')">
                <div class="card-content">
                    <div>
                        <h6>Total Classes</h6>
                        <h3>@ViewBag.TotalClasses</h3>
                    </div>
                    <div class="card-icon blue">
                        <i class="bi bi-book"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card" onclick="filterTable('taken')">
                <div class="card-content">
                    <div>
                        <h6>Attendance Taken</h6>
                        <h3>@ViewBag.AttendanceTaken</h3>
                    </div>
                    <div class="card-icon green">
                        <i class="bi bi-check-circle"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card" onclick="filterTable('pending')">
                <div class="card-content">
                    <div>
                        <h6>Pending</h6>
                        <h3>@ViewBag.Pending</h3>
                    </div>
                    <div class="card-icon orange">
                        <i class="bi bi-clock"></i>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="card-content">
                    <div>
                        <h6>Attendance %</h6>
                        <h3 id="percent">0%</h3>
                    </div>
                    <div class="card-icon red">
                        <i class="bi bi-pie-chart"></i>
                    </div>
                </div>
            </div>
        </div>

    </div>

    <div class="row">

        <div class="col-md-8">
            <div class="main-card p-3">

                <h5 id="reportTitle">Today's Classes</h5>

                <div class="table-wrapper">
                    <table class="table table-dark table-bordered text-center">
                        <thead>
                            <tr>
                                <th>Day</th>
                                <th>Time</th>
                                <th>Subject</th>
                                <th>Class</th>
                                <th>Status</th>
                            </tr>
                        </thead>

                        <tbody id="tableBody">
                            @foreach (var item in Model)
                            {
                                <tr data-status="@(item.IsAttendanceTaken?"taken":"pending")">
                                    <td>@item.DayOfWeek</td>
                                    <td>@item.Slot</td>
                                    <td>@item.SubjectName</td>
                                    <td>@item.ClassName</td>
                                    <td>
                                        @if (item.IsAttendanceTaken)
                                        {
                                            <span class="badge bg-success">Done</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Pending</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>

            </div>
        </div>

        <div class="col-md-4">
            <div class="main-card p-3">
                <h5>Attendance</h5>

                <div class="chart-container">
                    <canvas id="pieChart"></canvas>
                </div>

            </div>
        </div>

    </div>

</div>

<script>

function filterTable(type){

var rows=document.querySelectorAll("#tableBody tr");
var title=document.getElementById("reportTitle");

rows.forEach(function(row){

var status=row.getAttribute("data-status");

if(type=="all" || status==type)
row.style.display="";
else
row.style.display="none";

});

if(type=="all")
title.innerText="Today's Classes";
else if(type=="taken")
title.innerText="Attendance Taken";
else
title.innerText="Pending Classes";
}

var taken=@ViewBag.AttendanceTaken;
var pending=@ViewBag.Pending;

if(taken==0 && pending==0){
pending=1;
}

var total=taken+pending;

document.getElementById("percent").innerText=
Math.round((taken*100)/total)+"%";

new Chart(document.getElementById("pieChart"),{
type:"doughnut",
data:{
datasets:[{
data:[taken,pending],
backgroundColor:["#22c55e","#ef4444"],
borderWidth:0
}]
},
options:{
cutout:"70%"
}
});

</script>