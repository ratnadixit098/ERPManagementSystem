@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Header Start -->
<div class="container-fluid bg-primary py-5 mb-5 page-header">
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-10 text-center">
                <h1 class="display-3 text-white">About ERP System</h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb justify-content-center">
                        <li class="breadcrumb-item">
                            <a class="text-white" href="/">Home</a>
                        </li>
                        <li class="breadcrumb-item text-white active">
                            About
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>
<!-- Header End -->
<!-- Features Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-4">

            <div class="col-lg-3 col-sm-6">
                <div class="service-item text-center pt-3">
                    <div class="p-4">
                        <i class="fa fa-3x fa-user-graduate text-primary mb-4"></i>
                        <h5 class="mb-3">Student Management</h5>
                        <p>Manage student admission, profile and records.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-sm-6">
                <div class="service-item text-center pt-3">
                    <div class="p-4">
                        <i class="fa fa-3x fa-calendar-check text-primary mb-4"></i>
                        <h5 class="mb-3">Attendance Tracking</h5>
                        <p>Daily and hourly attendance monitoring system.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-sm-6">
                <div class="service-item text-center pt-3">
                    <div class="p-4">
                        <i class="fa fa-3x fa-money-bill text-primary mb-4"></i>
                        <h5 class="mb-3">Fees Management</h5>
                        <p>Track student fees and payment records.</p>
                    </div>
                </div>
            </div>

            <div class="col-lg-3 col-sm-6">
                <div class="service-item text-center pt-3">
                    <div class="p-4">
                        <i class="fa fa-3x fa-chart-line text-primary mb-4"></i>
                        <h5 class="mb-3">Reports & Analytics</h5>
                        <p>Generate academic and financial reports.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</div>
<!-- Features End -->
<!-- About Start -->
<div class="container-xxl py-5">
    <div class="container">
        <div class="row g-5">

            <div class="col-lg-6">
                <img class="img-fluid" src="~/Content/img/about.jpg" alt="">
            </div>

            <div class="col-lg-6">
                <h6 class="section-title bg-white text-start text-primary pe-3">
                    About ERP
                </h6>

                <h1 class="mb-4">
                    College ERP Management System
                </h1>

                <p class="mb-4">
                    ERP Management System is a centralized platform designed
                    to automate college administration processes. It helps
                    manage students, faculty, attendance, fees, timetable,
                    and academic records efficiently.
                </p>

                <p class="mb-4">
                    This system improves communication between departments
                    and provides real-time data access for administrators,
                    teachers, and students.
                </p>

                <div class="row gy-2 gx-4 mb-4">

                    <div class="col-sm-6">
                        <p>
                            <i class="fa fa-arrow-right text-primary me-2"></i>
                            Student Module
                        </p>
                    </div>

                    <div class="col-sm-6">
                        <p>
                            <i class="fa fa-arrow-right text-primary me-2"></i>
                            Faculty Module
                        </p>
                    </div>

                    <div class="col-sm-6">
                        <p>
                            <i class="fa fa-arrow-right text-primary me-2"></i>
                            Attendance Module
                        </p>
                    </div>

                    <div class="col-sm-6">
                        <p>
                            <i class="fa fa-arrow-right text-primary me-2"></i>
                            Fees Module
                        </p>
                    </div>

                    <div class="col-sm-6">
                        <p>
                            <i class="fa fa-arrow-right text-primary me-2"></i>
                            Timetable Module
                        </p>
                    </div>

                    <div class="col-sm-6">
                        <p>
                            <i class="fa fa-arrow-right text-primary me-2"></i>
                            Reports Module
                        </p>
                    </div>

                </div>

                <a class="btn btn-primary py-3 px-5">
                    Learn More
                </a>

            </div>
        </div>
    </div>
</div>
<!-- About End -->
<!-- Team Start -->
<div class="container-xxl py-5">
    <div class="container">

        <div class="text-center">
            <h6 class="section-title bg-white text-center text-primary px-3">
                Team
            </h6>
            <h1 class="mb-5">
                ERP System Modules
            </h1>
        </div>

        <div class="row g-4">

            <div class="col-lg-3 col-md-6">
                <div class="team-item bg-light text-center p-4">
                    <h5>Student Module</h5>
                    <small>Admission & Records</small>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="team-item bg-light text-center p-4">
                    <h5>Attendance Module</h5>
                    <small>Daily Tracking</small>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="team-item bg-light text-center p-4">
                    <h5>Fees Module</h5>
                    <small>Payment Management</small>
                </div>
            </div>

            <div class="col-lg-3 col-md-6">
                <div class="team-item bg-light text-center p-4">
                    <h5>Reports Module</h5>
                    <small>Analytics & Reports</small>
                </div>
            </div>

        </div>
    </div>
</div>
<!-- Team End -->