@model ERPManagementSystem.Models.Department
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: #f5f7fb;
    }
    body {
        background: #f5f7fb;
        background-image: url('/content/images/OIP (1).jfif');
        background-repeat: no-repeat;
        background-size: cover;
    }

    .form-card {
        border-radius: 18px;
        max-width: 800px;
        margin: auto;
    }

    .form-header {
        background: linear-gradient(135deg,#20c997,#0f9d7a);
        color: white;
        border-radius: 18px 18px 0 0;
        padding: 18px;
    }

    .form-control, .form-select {
        border-radius: 10px;
    }

    label {
        font-weight: 600;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="container mt-3" style="max-width:800px;">
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    </div>
}

<div class="container mt-4">
    <div class="card shadow form-card">

        <div class="form-header">
            <h4><i class="fa fa-sitemap"></i> Department Entry</h4>
        </div>

        <div class="card-body">

            @using (Html.BeginForm())
            {
                <div class="row g-3">

                    <div class="col-sm-6">
                        <label>Department Code</label>
                        @Html.TextBoxFor(x => x.DepartmentCode, new { @class = "form-control", required = "required" })
                    </div>

                    <div class="col-sm-6">
                        <label>Department Name</label>
                        @Html.TextBoxFor(x => x.DepartmentName, new { @class = "form-control", required = "required" })
                    </div>

                    <div class="col-sm-6">
                        <label>College</label>
                        @Html.DropDownListFor(x => x.CollegeId,
                            ViewBag.CollegeList as IEnumerable<SelectListItem>,
                            "Select College",
                            new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-sm-6">
                        <label>Description</label>
                        @Html.TextBoxFor(x => x.Description, new { @class = "form-control", required = "required" })
                    </div>

                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="fa fa-save"></i> Save Department
                    </button>
                </div>
            }

        </div>
    </div>
</div>