@{
    ViewBag.Title = "StudentDashboard";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}
<main class="flex-1 overflow-y-auto bg-black p-8">

    <header class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-2xl font-bold text-white">Dashboard</h1>
            <p class="text-gray-500 text-sm">Welcome back! Here's your schedule for today.</p>
        </div>
        <div class="flex items-center space-x-4">
            <button class="bg-indigo-600 hover:bg-indigo-700 text-white px-4 py-2 rounded-lg text-sm font-medium transition">
                + New Task
            </button>
        </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="card p-6">
            <div class="flex justify-between items-start mb-4">
                <span class="text-gray-400 text-sm">Attendance</span>
                <i class="fas fa-user-check text-indigo-500"></i>
            </div>
            <h2 class="text-2xl font-bold">92%</h2>
            <p class="text-green-500 text-xs mt-2">+2.5% vs last month</p>
        </div>
        <div class="card p-6">
            <div class="flex justify-between items-start mb-4">
                <span class="text-gray-400 text-sm">Assignments</span>
                <i class="fas fa-tasks text-green-500"></i>
            </div>
            <h2 class="text-2xl font-bold">14 / 16</h2>
            <p class="text-gray-500 text-xs mt-2">2 Pending tasks</p>
        </div>
        <div class="card p-6">
            <div class="flex justify-between items-start mb-4">
                <span class="text-gray-400 text-sm">Upcoming Tests</span>
                <i class="fas fa-clock text-yellow-500"></i>
            </div>
            <h2 class="text-2xl font-bold">03</h2>
            <p class="text-red-500 text-xs mt-2">-1.0% change</p>
        </div>
        <div class="card p-6">
            <div class="flex justify-between items-start mb-4">
                <span class="text-gray-400 text-sm">Library Credits</span>
                <i class="fas fa-book text-purple-500"></i>
            </div>
            <h2 class="text-2xl font-bold">284</h2>
            <p class="text-green-500 text-xs mt-2">+24.7% usage</p>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">

        <div class="lg:col-span-2 card overflow-hidden">

            <div class="lg:col-span-2 card overflow-hidden border border-gray-800 rounded-xl bg-[#1a1a1a]">
                <div class="p-6 border-b border-gray-800 flex justify-between items-center bg-[#1c1c1c]">
                    <div>
                        <h3 class="text-lg font-semibold text-white uppercase tracking-wider">Weekly Academic Schedule</h3>
                        <p class="text-xs text-gray-500 italic">Logged in as: <span class="text-indigo-400 font-medium">Anupam Pal</span></p>
                    </div>
                    <div class="text-right">
                        <span class="bg-indigo-900/30 text-indigo-400 text-[10px] font-bold px-2 py-1 rounded uppercase">7 Days View</span>
                    </div>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse">
                        <thead>
                            <tr class="text-gray-500 text-xs uppercase bg-[#141414] border-b border-gray-800">
                                <th class="p-4 border-r border-gray-800 w-24 text-center">Day</th>
                                <th class="p-4 text-center">09:00 - 11:00</th>
                                <th class="p-4 text-center">11:00 - 01:00</th>
                                <th class="p-4 text-center bg-gray-900/80 w-20">Lunch</th>
                                <th class="p-4 text-center">02:00 - 04:00</th>
                                <th class="p-4 text-center">04:00 - 06:00</th>
                            </tr>
                        </thead>
                        <tbody class="text-sm divide-y divide-gray-800">
                            <tr class="hover:bg-gray-800/20">
                                <td class="p-4 bg-[#141414] font-bold text-indigo-400 border-r border-gray-800 text-center uppercase">Mon</td>
                                <td class="p-4 text-center">
                                    <div class="text-white font-medium">.NET MVC</div>
                                    <div class="text-[10px] text-gray-500">Prof. Anand</div>
                                </td>
                                <td class="p-4 text-center">
                                    <div class="text-white font-medium">SQL Admin</div>
                                    <div class="text-[10px] text-gray-500">Dr. Rajesh</div>
                                </td>
                                <td rowspan="7" class="bg-gray-900/60 border-l border-r border-gray-800 relative">
                                    <div class="flex flex-col items-center justify-center h-full min-h-[400px]">
                                        <img src="https://cdn-icons-png.flaticon.com/512/706/706164.png" alt="Lunch" class="w-8 h-8 opacity-30 mb-4 grayscale">
                                        <span class="[writing-mode:vertical-lr] font-black text-gray-700 tracking-[12px] uppercase text-lg opacity-40">LUNCH BREAK</span>
                                    </div>
                                </td>
                                <td class="p-4 text-center">
                                    <div class="text-white font-medium">Entity Framework</div>
                                    <div class="text-[10px] text-gray-500">Mr. Suresh</div>
                                </td>
                                <td class="p-4 text-center">
                                    <div class="text-white font-medium">UI/UX Design</div>
                                    <div class="text-[10px] text-gray-500">Ms. Neha</div>
                                </td>
                            </tr>

                            <tr class="hover:bg-gray-800/20">
                                <td class="p-4 bg-[#141414] font-bold text-indigo-400 border-r border-gray-800 text-center uppercase">Tue</td>
                                <td class="p-4 text-center"><div class="text-white font-medium">C# Advanced</div><div class="text-[10px] text-gray-500">Prof. Anand</div></td>
                                <td class="p-4 text-center"><div class="text-white font-medium">Web API</div><div class="text-[10px] text-gray-500">Mr. Amit</div></td>
                                <td class="p-4 text-center"><div class="text-white font-medium">JavaScript</div><div class="text-[10px] text-gray-500">Ms. Priya</div></td>
                                <td class="p-4 text-center font-light text-gray-600 italic">Self Study</td>
                            </tr>

                            <tr class="hover:bg-gray-800/20">
                                <td class="p-4 bg-[#141414] font-bold text-indigo-400 border-r border-gray-800 text-center uppercase">Wed</td>
                                <td class="p-4 text-center" colspan="2"><div class="text-indigo-300 font-medium text-lg uppercase">Full Stack Workshop</div><div class="text-[10px] text-gray-500 italic">Main Lab - Dr. Verma</div></td>
                                <td class="p-4 text-center"><div class="text-white font-medium">Azure Basics</div><div class="text-[10px] text-gray-500">Mr. Khan</div></td>
                                <td class="p-4 text-center"><div class="text-white font-medium">Git & GitHub</div><div class="text-[10px] text-gray-500">Mr. Rawat</div></td>
                            </tr>

                            <tr class="hover:bg-gray-800/20">
                                <td class="p-4 bg-[#141414] font-bold text-indigo-400 border-r border-gray-800 text-center uppercase">Thu</td>
                                <td class="p-4 text-center"><div class="text-white font-medium">Data Structures</div><div class="text-[10px] text-gray-500">Prof. Sinha</div></td>
                                <td class="p-4 text-center"><div class="text-white font-medium">DotNet Core</div><div class="text-[10px] text-gray-500">Prof. Anand</div></td>
                                <td class="p-4 text-center"><div class="text-white font-medium">Project Mentoring</div><div class="text-[10px] text-gray-500">Admin</div></td>
                                <td class="p-4 text-center font-light text-gray-600 italic">Library Session</td>
                            </tr>

                            <tr class="hover:bg-gray-800/20">
                                <td class="p-4 bg-[#141414] font-bold text-indigo-400 border-r border-gray-800 text-center uppercase">Fri</td>
                                <td class="p-4 text-center"><div class="text-white font-medium">Software Testing</div><div class="text-[10px] text-gray-500">Ms. Pooja</div></td>
                                <td class="p-4 text-center"><div class="text-white font-medium">SQL Queries</div><div class="text-[10px] text-gray-500">Dr. Rajesh</div></td>
                                <td class="p-4 text-center" colspan="2"><div class="text-green-400 font-medium">Presentation & Viva</div><div class="text-[10px] text-gray-500 italic">Panel Room A</div></td>
                            </tr>

                            <tr class="hover:bg-gray-800/20 bg-indigo-900/5">
                                <td class="p-4 bg-[#1d1d1d] font-bold text-yellow-500 border-r border-gray-800 text-center uppercase text-xs">Sat</td>
                                <td class="p-4 text-center" colspan="2"><div class="text-white font-light italic">Technical Seminar / Guest Lecture</div></td>
                                <td class="p-4 text-center" colspan="2"><div class="text-white font-light italic">Extra-Curricular Activities</div></td>
                            </tr>

                            <tr class="bg-red-900/5">
                                <td class="p-4 bg-[#1d1d1d] font-bold text-red-500 border-r border-gray-800 text-center uppercase text-xs">Sun</td>
                                <td class="p-6 text-center text-red-400/50 font-bold tracking-widest uppercase italic" colspan="5">
                                    <i class="fas fa-bed mr-2"></i> Weekly Holiday - Institute Closed
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="space-y-6">
            <div class="card p-6">
                <h3 class="text-md font-semibold mb-4">Course Progress</h3>
                <div class="flex items-center justify-center py-4">
                    <div class="relative w-32 h-32 rounded-full border-8 border-gray-800 flex items-center justify-center">
                        <div class="absolute inset-0 border-8 border-indigo-500 rounded-full" style="clip-path: inset(0 0 50% 0);"></div>
                        <span class="text-xl font-bold">76%</span>
                    </div>
                </div>
                <div class="mt-4 space-y-2 text-xs">
                    <div class="flex justify-between"><span>Completed</span><span class="text-gray-400">12 Units</span></div>
                    <div class="flex justify-between"><span>Remaining</span><span class="text-gray-400">4 Units</span></div>
                </div>
            </div>

            <div class="card p-6">
                <h3 class="text-md font-semibold mb-4">Monthly Goals</h3>
                <div class="space-y-4">
                    <div>
                        <div class="flex justify-between text-xs mb-1"><span>Attendance</span><span>88%</span></div>
                        <div class="w-full bg-gray-800 h-1.5 rounded-full"><div class="bg-blue-500 h-1.5 rounded-full w-[88%]"></div></div>
                    </div>
                    <div>
                        <div class="flex justify-between text-xs mb-1"><span>Practical Score</span><span>75%</span></div>
                        <div class="w-full bg-gray-800 h-1.5 rounded-full"><div class="bg-orange-500 h-1.5 rounded-full w-[75%]"></div></div>
                    </div>
                </div>
            </div>
        </div>

    </div>
</main>

