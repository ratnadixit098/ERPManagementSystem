<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student Dashboard - Student Portal</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body {
            background-color: #0d0d0d;
            color: #e5e7eb;
            font-family: 'Inter', sans-serif;
        }

        .sidebar {
            background-color: #121212;
            border-right: 1px solid #262626;
        }

        .card {
            background-color: #1a1a1a;
            border: 1px solid #262626;
            border-radius: 12px;
        }

        .sidebar-item:hover {
            background-color: #1f1f1f;
            color: #6366f1;
        }

        .active-link {
            background-color: #1f1f1f;
            color: #6366f1;
            border-left: 3px solid #6366f1;
        }
    </style>
</head>
<body class="flex h-screen overflow-hidden">

    <aside class="sidebar w-64 flex-shrink-0 flex flex-col">
        <div class="p-6 flex items-center space-x-3">
            <div class="w-8 h-8 bg-indigo-600 rounded-lg flex items-center justify-center italic font-bold">S</div>
            <span class="text-xl font-bold tracking-tight text-white">Student</span>
        </div>

        <nav class="flex-1 px-4 space-y-1 overflow-y-auto">
            <div class="text-xs font-semibold text-gray-500 uppercase px-3 py-4">Overview</div>
            <a href="#" class="sidebar-item active-link flex items-center px-3 py-2 rounded-md transition-all">
                <i class="fas fa-th-large mr-3"></i> Dashboard
            </a>
            <a href="#" class="sidebar-item flex items-center px-3 py-2 text-gray-400 rounded-md">
                <i class="fas fa-chart-line mr-3"></i> Analytics
            </a>
            <a href="#" class="sidebar-item flex items-center px-3 py-2 text-gray-400 rounded-md">
                <i class="fas fa-shopping-cart mr-3"></i> eCommerce
            </a>

            <div class="text-xs font-semibold text-gray-500 uppercase px-3 py-4">Apps</div>
            <a href="#" class="sidebar-item flex items-center px-3 py-2 text-gray-400 rounded-md">
                <i class="fas fa-envelope mr-3"></i> Mail
            </a>
            <a href="#" class="sidebar-item flex items-center px-3 py-2 text-gray-400 rounded-md">
                <i class="fas fa-calendar-alt mr-3"></i> Calendar
            </a>
        </nav>

        <div class="p-4 border-t border-gray-800">
            <div class="flex items-center space-x-3 bg-gray-900 p-2 rounded-lg">
                <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center text-xs font-bold text-white">AP</div>
                <div>
                    <p class="text-sm font-medium text-white leading-none">Anupam Pal</p>
                    <p class="text-xs text-gray-500">Admin</p>
                </div>
            </div>
        </div>
    </aside>

    @RenderBody()


</body>
</html>