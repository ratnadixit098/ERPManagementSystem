<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - ERP System</title>

    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet">
    <link href="~/Content/bootstrap.min.css" rel="stylesheet" />

    <style>
        :root {
            --sidebar-width: 260px;
            --bg-dark: #020617;
            --card-dark: #0f172a;
            --accent-blue: #3b82f6;
            --accent-emerald: #10b981;
        }

        body {
            margin: 0;
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: var(--bg-dark);
            color: #f1f5f9;
            min-height: 100vh;
            overflow-x: hidden;
        }

        /* ✨ Header Styling */
        .header {
            height: 70px;
            background: rgba(15, 23, 42, 0.8);
            backdrop-filter: blur(10px);
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 30px;
            border-bottom: 1px solid rgba(255, 255, 255, 0.05);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

            .header h2 {
                margin: 0;
                font-size: 20px;
                font-weight: 700;
                background: linear-gradient(to right, #fff, #94a3b8);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }

        /* 👤 User Menu Glow */
        .user-menu {
            position: relative;
            cursor: pointer;
            background: rgba(255, 255, 255, 0.05);
            padding: 8px 16px;
            border-radius: 12px;
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: 0.3s;
            display: flex;
            align-items: center;
            gap: 10px;
        }

            .user-menu:hover {
                background: rgba(59, 130, 246, 0.1);
                border-color: var(--accent-blue);
            }

        .dropdown {
            display: none;
            position: absolute;
            top: 55px;
            right: 0;
            background: #1e293b;
            border-radius: 12px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            min-width: 180px;
            z-index: 1100;
            border: 1px solid rgba(255,255,255,0.1);
            padding: 8px;
        }

            .dropdown a {
                display: flex;
                align-items: center;
                gap: 10px;
                padding: 10px 15px;
                text-decoration: none;
                color: #ffb4b4;
                font-weight: 500;
                border-radius: 8px;
            }

                .dropdown a:hover {
                    background: rgba(239, 68, 68, 0.1);
                    color: #ef4444;
                }

        /* 📟 Layout Wrapper */
        .main-wrapper {
            display: flex;
        }

        /* 🚀 Sidebar Styling */
        .sidebar {
            width: var(--sidebar-width);
            height: calc(100vh - 70px);
            background: linear-gradient(180deg, rgba(15, 23, 42, 0.95), rgba(2, 6, 23, 1));
            border-right: 1px solid rgba(255, 255, 255, 0.05);
            padding: 20px 15px;
            position: fixed;
            left: 0;
            overflow-y: auto;
        }

            .sidebar h3 {
                font-size: 12px;
                text-transform: uppercase;
                letter-spacing: 1.5px;
                color: var(--accent-blue);
                font-weight: 700;
                margin-bottom: 25px;
                padding-left: 10px;
            }

            .sidebar a {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 12px 15px;
                color: #94a3b8;
                text-decoration: none;
                font-size: 14px;
                font-weight: 500;
                border-radius: 12px;
                margin-bottom: 5px;
                transition: 0.3s;
            }

                .sidebar a i {
                    width: 20px;
                    font-size: 16px;
                }

                .sidebar a:hover {
                    background: rgba(255, 255, 255, 0.05);
                    color: #fff;
                    transform: translateX(5px);
                }

                /* Sidebar Active State Glow */
                .sidebar a.active {
                    background: linear-gradient(90deg, rgba(59, 130, 246, 0.15), transparent);
                    color: var(--accent-blue);
                    border-left: 3px solid var(--accent-blue);
                }

        /* 🌑 Content Area */
        .content {
            flex: 1;
            margin-left: var(--sidebar-width);
            padding: 30px;
            min-height: calc(100vh - 70px);
            /* Soft radial glow in content area background */
            background: radial-gradient(at 50% 50%, rgba(30, 58, 138, 0.05) 0, transparent 80%);
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: var(--bg-dark);
        }

        ::-webkit-scrollbar-thumb {
            background: #334155;
            border-radius: 10px;
        }
    </style>
</head>

<body>

    <div class="header">
        <h2><i class="fa fa-shield-halved text-primary me-2"></i> Principal Panel</h2>

        <div class="user-menu" id="userMenu">
            <i class="fa fa-circle-user fs-5 text-info"></i>
            <span>@Session["UserName"]</span>
            <i class="fa fa-chevron-down small"></i>

            <div class="dropdown" id="dropdown">
                <a href="/Login/Logout">
                    <i class="fas fa-power-off"></i> Logout Account
                </a>
            </div>
        </div>
    </div>

    <div class="main-wrapper">

        <div class="sidebar">
            <h3>Management</h3>

            <a href="/PrincipalDashboard/PrincipalDashboard" class="active"><i class="fa fa-chart-pie"></i> Dashboard</a>
            <a href="/Student/Create"><i class="fa fa-user-plus"></i> Student Admission</a>
            <a href="/Commitment/Create"><i class="fa fa-handshake"></i> Fees Commitment</a>
            <a href="/Attendance/TimeTable"><i class="fa fa-money-check-dollar"></i> Mark Attendance</a>

            <h3 class="mt-4">Academic Setup</h3>
            <a href="/Department/Create"><i class="fa fa-building-user"></i> Departments</a>
            <a href="/Course/Create"><i class="fa fa-book-open"></i> Courses</a>
            <a href="/Class/Create"><i class="fa fa-chalkboard-user"></i> Classes</a>
            <a href="/Subject/Create"><i class="fa fa-book"></i> Subjects</a>
            <a href="/Teacher/Create"><i class="fa fa-user-tie"></i> Teacher Entry</a>
        </div>

        <div class="content">
            @RenderBody()
        </div>

    </div>

    <script>
        $(document).ready(function () {
            // Dropdown Toggle
            $('#userMenu').on('click', function (e) {
                e.stopPropagation();
                $('#dropdown').fadeToggle(150);
            });

            $(document).on('click', function () {
                $('#dropdown').fadeOut(150);
            });

            // Auto-Highlight Active Sidebar Link based on URL
            var currentPath = window.location.pathname;
            $('.sidebar a').each(function () {
                if ($(this).attr('href') === currentPath) {
                    $('.sidebar a').removeClass('active');
                    $(this).addClass('active');
                }
            });
        });
    </script>

</body>
</html>