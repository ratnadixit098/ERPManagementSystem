@model ERPManagementSystem.Models.Timetable
@{
    Layout = "~/Views/Shared/Principal.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: #f5f7fb;
    }

    body {
        background: #f5f7fb;
        background-image: url('/content/images/OIP (1).jfif');
        background-repeat: no-repeat;
        background-size: cover;
    }

    .form-card {
        border-radius: 18px;
        max-width: 850px;
        margin: auto;
    }

    .form-header {
        background: linear-gradient(135deg,#007bff,#004085);
        color: white;
        border-radius: 18px 18px 0 0;
        padding: 18px;
    }

    .form-control, .form-select {
        border-radius: 10px;
    }

    label {
        font-weight: 600;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="container mt-3" style="max-width:850px;">
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    </div>
}

<div class="container mt-4">
    <div class="card shadow form-card">

        <div class="form-header">
            <h4><i class="fa fa-calendar"></i> Timetable Entry</h4>
        </div>

        <div class="card-body">

            @using (Html.BeginForm())
            {
                <div class="row g-3">

                    <div class="col-sm-6">
                        <label>Class</label>
                        @Html.DropDownListFor(x => x.ClassId,
                        ViewBag.ClassList as IEnumerable<SelectListItem>,
                        "Select Class",
                        new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-sm-6">
                        <label>Subject</label>
                        @Html.DropDownListFor(x => x.SubjectId,
                        ViewBag.SubjectList as IEnumerable<SelectListItem>,
                        "Select Subject",
                        new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-sm-6">
                        <label>Teacher</label>
                        @Html.DropDownListFor(x => x.TeacherId,
                        ViewBag.TeacherList as IEnumerable<SelectListItem>,
                        "Select Teacher",
                        new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-sm-6">
                        <label>Day</label>
                        @Html.DropDownListFor(x => x.DayOfWeek,
                        ViewBag.DayList as IEnumerable<SelectListItem>,
                        "Select Day",
                        new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-sm-6">
                        <label>Start Time</label>
                        @Html.TextBoxFor(x => x.StartTime, "{0:hh:mm tt}",
                        new { @class = "form-control", type = "time" })

                    </div>

                    <div class="col-sm-6">
                        <label>End Time</label>
                        @Html.TextBoxFor(x => x.EndTime, "{0:hh:mm tt}",
                        new { @class = "form-control", type = "time", required = "required" })
                    </div>

                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success">
                        <i class="fa fa-save"></i> Save Timetable
                    </button>
                </div>
            }

        </div>
    </div>
</div>
<script>document.getElementById("timeInput").addEventListener("change", function () {

        let time = this.value; // 13:00
        if (!time) return;

        let [hours, minutes] = time.split(':');

        let ampm = hours >= 12 ? 'PM' : 'AM';
        hours = hours % 12 || 12;

        let formattedTime = hours + ":" + minutes + " " + ampm;

        document.getElementById("ampmTime").value = formattedTime;
});
    </script>