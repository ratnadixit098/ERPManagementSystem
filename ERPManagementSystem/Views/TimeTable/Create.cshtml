@model ERPManagementSystem.Models.Timetable
@{
    Layout = "~/Views/Shared/Principal.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    /* Main Background */
    body {
        background-color: #0c1327;
        color: #ffffff;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    /* Card Styling */
    .form-card {
        background-color: #161d31; /* Slightly lighter than body for depth */
        border: 1px solid #283046;
        border-radius: 15px;
        max-width: 850px;
        margin: 40px auto;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    /* Header Styling */
    .form-header {
        background: linear-gradient(135deg, #0e162a, #1a237e);
        color: white;
        border-radius: 15px 15px 0 0;
        padding: 20px;
        border-bottom: 1px solid #283046;
    }

    /* Input & Select Styling */
    .form-label {
        font-weight: 500;
        color: #b4b7bd; /* Muted white for labels */
        margin-bottom: 8px;
    }

    .form-control, .form-select {
        background-color: #0c1327;
        border: 1px solid #404656;
        color: #ffffff !important;
        border-radius: 8px;
        padding: 10px;
    }

        /* Focus effect */
        .form-control:focus, .form-select:focus {
            background-color: #0c1327;
            border-color: #3751FF;
            box-shadow: 0 0 0 0.25rem rgba(55, 81, 255, 0.25);
            color: #fff;
        }

        /* Dropdown options color for some browsers */
        .form-select option {
            background-color: #161d31;
            color: #fff;
        }

    /* Button Styling */
    .btn-save {
        background: #00ac69;
        border: none;
        padding: 12px 30px;
        font-weight: 600;
        color: white;
        border-radius: 8px;
        transition: all 0.3s ease;
    }

        .btn-save:hover {
            background: #008a54;
            transform: translateY(-2px);
            color: white;
            box-shadow: 0 5px 15px rgba(0, 172, 105, 0.3);
        }

    /* Success Alert */
    .alert-success {
        background-color: #161d31;
        border: 1px solid #00ac69;
        color: #00ac69;
        border-radius: 10px;
        max-width: 850px;
        margin: 20px auto 0;
    }
</style>

@if (TempData["Success"] != null)
{
    <div class="container">
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fa fa-check-circle me-2"></i> @TempData["Success"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    </div>
}

<div class="container">
    <div class="card form-card">
        <div class="form-header">
            <h4 class="mb-0"><i class="fa fa-calendar-alt me-2"></i> Timetable Entry</h4>
            <p class="mb-0 small text-white-50">Create and manage schedule for classes and teachers</p>
        </div>

        <div class="card-body p-4">
            @using (Html.BeginForm())
            {
                <div class="row g-4">
                    <div class="col-sm-6">
                        <label class="form-label">Class</label>
                        @Html.DropDownListFor(x => x.ClassId,
                                  ViewBag.ClassList as IEnumerable<SelectListItem>,
                                  "Select Class",
                                  new { @class = "form-select", required = "required" ,id= "Class" })
                    </div>

                    <div class="col-sm-6">
                        <label class="form-label">Subject</label>
                        @Html.DropDownListFor(x => x.SubjectId,
                                  ViewBag.SubjectList as IEnumerable<SelectListItem>,
                                  "Select Subject",
                                  new { @class = "form-select", required = "required" ,id= "SubjectId" })
                    </div>

                    <div class="col-sm-6">
                        <label class="form-label">Teacher</label>
                        @Html.DropDownListFor(x => x.TeacherId,
                                  ViewBag.TeacherList as IEnumerable<SelectListItem>,
                                  "Select Teacher",
                                  new { @class = "form-select", required = "required",id= "TeacherId" })
                    </div>

                    <div class="col-sm-6">
                        <label class="form-label">Day of Week</label>
                        @Html.DropDownListFor(x => x.DayOfWeek,
                                  ViewBag.DayList as IEnumerable<SelectListItem>,
                                  "Select Day",
                                  new { @class = "form-select", required = "required" ,id= "DayOfWeek" })
                    </div>

                    <div class="col-sm-6">
                        <label class="form-label">Start Time</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-white-50" style="border: 1px solid #404656;">
                                <i class="fa fa-clock"></i>
                            </span>
                            @Html.TextBoxFor(x => x.StartTime, "{0:HH:mm}",
                                      new { @class = "form-control border-start-0", type = "time", required = "required",id= "StartTime" })
                        </div>
                    </div>

                    <div class="col-sm-6">
                        <label class="form-label">End Time</label>
                        <div class="input-group">
                            <span class="input-group-text bg-transparent border-end-0 text-white-50" style="border: 1px solid #404656;">
                                <i class="fa fa-hourglass-end"></i>
                            </span>
                            @Html.TextBoxFor(x => x.EndTime, "{0:HH:mm}",
                                      new { @class = "form-control border-start-0", type = "time", required = "required",id= "EndTime" })
                        </div>
                    </div>
                </div>

                <hr class="my-4" style="border-top: 1px solid #283046; opacity: 1;" />

                <div class="text-end">
                    <button type="button" class="btn btn-outline-secondary me-2" onclick="window.history.back()">
                        Cancel
                    </button>
                    <button type="submit" class="btn btn-save">
                        <i class="fa fa-save me-2"></i> Save Timetable
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>




<script>
    $("#StartTime, #EndTime, #TeacherId, #DayOfWeek,#Class").on("change", function () {

        var teacherId = $("#TeacherId").val();
        var day = $("#DayOfWeek").val();
        var start = $("#StartTime").val();
        var end = $("#EndTime").val();
        var classId = $("#Class").val();

        if (teacherId && day && start && end && classId) {

            $.ajax({
                url: '/Timetable/CheckTeacherConflict',
                type: 'POST',
                data: {
                    TeacherId: teacherId,
                    DayOfWeek: day,
                    StartTime: start,
                    EndTime: end,
                    Class: classId
                },
                success: function (res) {
                    if (res !== "") {
                        $("#msg").text(res);   // dynamic message
                        alert(res);            // optional popup

                        $('#StartTime').val('');
                        $('#EndTime').val('');
                    } else {
                        $("#msg").text("");
                    }
                }
            });
        }
    });
</script>