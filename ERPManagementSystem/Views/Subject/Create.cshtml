@model ERPManagementSystem.Models.Subject

@{
    Layout = "~/Views/Shared/Principal.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    /* ✨ Theme Consistency */
    body {
        background-color: #020617 !important;
        color: #f1f5f9 !important;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }

    /* 💎 Modern Glassmorphism Card */
    .form-card {
        background: rgba(15, 23, 42, 0.7);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 28px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.6);
        max-width: 900px;
        margin: auto;
        overflow: hidden;
    }

    /* 🎨 Header Styling */
    .form-header {
        background: rgba(255, 255, 255, 0.03);
        padding: 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .header-icon {
        width: 50px;
        height: 50px;
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        color: white;
        box-shadow: 0 8px 20px rgba(6, 182, 212, 0.3);
    }

    .form-header h4 {
        margin: 0;
        font-weight: 700;
        letter-spacing: -0.5px;
        background: linear-gradient(to right, #fff, #94a3b8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ⚡ Form Controls */
    label {
        font-size: 13px;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 10px;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        display: block;
    }

    .form-control, .form-select {
        background: rgba(2, 6, 23, 0.5) !important;
        border: 1px solid #334155 !important;
        color: #f1f5f9 !important;
        border-radius: 14px;
        padding: 12px 18px;
        font-size: 15px;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #06b6d4 !important;
            box-shadow: 0 0 0 4px rgba(6, 182, 212, 0.15) !important;
            background: rgba(2, 6, 23, 0.8) !important;
            transform: translateY(-1px);
        }

    /* 🚀 Buttons */
    .btn-save {
        background: linear-gradient(135deg, #06b6d4, #0891b2);
        color: white;
        border: none;
        border-radius: 14px;
        padding: 14px 32px;
        font-weight: 700;
        transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        box-shadow: 0 10px 15px -3px rgba(6, 182, 212, 0.3);
    }

        .btn-save:hover {
            transform: translateY(-3px);
            box-shadow: 0 20px 25px -5px rgba(6, 182, 212, 0.4);
            filter: brightness(1.1);
        }

    .btn-reset {
        background: rgba(255, 255, 255, 0.05);
        color: #94a3b8;
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 14px;
        padding: 14px 28px;
        font-weight: 600;
        transition: 0.3s;
    }

        .btn-reset:hover {
            background: rgba(255, 255, 255, 0.1);
            color: #fff;
        }

    /* ✅ Modern Alert */
    .alert-modern {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #34d399;
        border-radius: 18px;
        padding: 18px 25px;
        margin-bottom: 30px;
        backdrop-filter: blur(8px);
    }
</style>

<div class="container container-main">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-modern d-flex align-items-center mx-auto animate__animated animate__fadeInDown" style="max-width:900px;">
            <i class="fa-solid fa-circle-check fs-4 me-3"></i>
            <div>
                <strong class="d-block">Success!</strong>
                <span class="small">@TempData["Success"]</span>
            </div>
        </div>
    }

    <div class="card form-card">
        <div class="form-header">
            <div class="header-icon">
                <i class="fa fa-book-bookmark"></i>
            </div>
            <div>
                <h4>Subject Management</h4>
                <small class="text-muted">Configure academic curriculum and credit points</small>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">
            @using (Html.BeginForm())
            {
                <div class="row g-4">

                    <div class="col-md-6">
                        <label><i class="fa fa-graduation-cap me-2 text-info"></i>Academic Course</label>
                        @Html.DropDownListFor(x => x.CourseId,
                            ViewBag.CourseList as IEnumerable<SelectListItem>,
                            "Select Course",
                            new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-layer-group me-2 text-info"></i>Target Semester</label>
                        @Html.TextBoxFor(x => x.Semester, new { @class = "form-control", type = "number", required = "required", placeholder = "e.g. 1" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-fingerprint me-2 text-info"></i>Subject Code</label>
                        @Html.TextBoxFor(x => x.SubjectCode, new { @class = "form-control", required = "required", placeholder = "e.g. CS-201" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-spell-check me-2 text-info"></i>Subject Title</label>
                        @Html.TextBoxFor(x => x.SubjectName, new { @class = "form-control", required = "required", placeholder = "e.g. Database Systems" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-award me-2 text-info"></i>Credit Points</label>
                        @Html.TextBoxFor(x => x.Credits, new { @class = "form-control", type = "number", required = "required", placeholder = "e.g. 4" })
                    </div>

                </div>

                <div class="d-flex justify-content-end align-items-center gap-3 mt-5 pt-4 border-top border-white border-opacity-10">
                    <button type="reset" class="btn btn-reset">
                        <i class="fa fa-rotate-left me-2"></i> Clear Form
                    </button>
                    <button type="submit" class="btn btn-save">
                        <i class="fa fa-cloud-arrow-up me-2"></i> Finalize & Save
                    </button>
                </div>
            }
        </div>
    </div>
</div>