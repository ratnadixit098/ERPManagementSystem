@model List<ERPManagementSystem.Models.Timetable>
@{
    Layout = "~/Views/Shared/StudentLayout.cshtml";
}
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
    body {
        background: #0b0f19;
        color: #fff;
        font-family: Segoe UI;
    }

    /* cards */
    .dashboard-card {
        background: rgba(17,24,39,.6);
        border-radius: 12px;
        padding: 18px;
        border: 1px solid rgba(255,255,255,.05);
        backdrop-filter: blur(6px);
        height: 105px;
        display: flex;
        align-items: center;
        position: relative;
        color: white;
    }

        .dashboard-card::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 2px;
            background: linear-gradient(90deg,#3b82f6,#22c55e,#f59e0b,#ef4444);
            border-radius: 12px 12px 0 0;
        }

    .card-content {
        display: flex;
        justify-content: space-between;
        align-items: center;
        width: 100%;
    }

    .dashboard-card h6 {
        font-weight: 600;
        color: #ffffff;
    }

    .dashboard-card h3 {
        font-weight: 700;
        color: #ffffff;
    }

    .card-icon {
        width: 45px;
        height: 45px;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
    }

    .blue {
        background: rgba(59,130,246,.15);
        color: #3b82f6;
        box-shadow: 0 0 15px rgba(59,130,246,.5);
    }

    .green {
        background: rgba(34,197,94,.15);
        color: #22c55e;
        box-shadow: 0 0 15px rgba(34,197,94,.5);
    }

    .orange {
        background: rgba(245,158,11,.15);
        color: #f59e0b;
        box-shadow: 0 0 15px rgba(245,158,11,.5);
    }

    .red {
        background: rgba(239,68,68,.15);
        color: #ef4444;
        box-shadow: 0 0 15px rgba(239,68,68,.5);
    }

    .main-card {
        background: rgba(17,24,39,.6);
        border-radius: 12px;
        border: 1px solid rgba(255,255,255,.05);
        backdrop-filter: blur(6px);
        height: 100%;
    }

    .present {
        background: rgba(34,197,94,.15);
        color: #22c55e;
        font-weight: 600;
    }

    .absent {
        background: rgba(239,68,68,.15);
        color: #ef4444;
        font-weight: 600;
    }

    .pending {
        background: rgba(59,130,246,.15);
        color: #3b82f6;
    }

    .lunch {
        background: rgba(245,158,11,.15);
        color: #f59e0b;
        font-weight: 600;
    }

    .chart-container {
        width: 100%;
        max-width: 300px;
        margin: auto;
    }
</style>


<div class="container-fluid mt-3">

    <div class="row mb-3">

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="card-content">
                    <div>
                        <h6>Total Subjects</h6>
                        <h3>@ViewBag.TotalSubjects</h3>
                    </div>
                    <div class="card-icon blue"><i class="bi bi-book"></i></div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="card-content">
                    <div>
                        <h6 style="color:white">Attendance</h6>
                        <h3 id="percent">0%</h3>
                    </div>
                    <div class="card-icon green"><i class="bi bi-check-circle"></i></div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="card-content">
                    <div>
                        <h6>Total Lectures</h6>
                        <h3>@ViewBag.TotalLectures</h3>
                    </div>
                    <div class="card-icon orange"><i class="bi bi-clock"></i></div>
                </div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="dashboard-card">
                <div class="card-content">
                    <div>
                        <h6>Pending Fees</h6>
                        <h3>₹@ViewBag.PendingFees</h3>
                    </div>
                    <div class="card-icon red"><i class="bi bi-currency-rupee"></i></div>
                </div>
            </div>
        </div>

    </div>


    <div class="row">

        <div class="col-md-8">
            <div class="main-card p-3">
                <h5 class="mb-3" style="color:white">Timetable</h5>

                <table class="table table-dark table-bordered text-center">
                    <thead>
                        <tr>
                            <th>Day</th>
                            <th>9-10</th>
                            <th>10-11</th>
                            <th>11-12</th>
                            <th>12-1</th>
                            <th>1-2</th>
                            <th>2-3</th>
                            <th>3-4</th>
                            <th>4-5</th>
                        </tr>
                    </thead>

                    <tbody>

                        @{
                            int present = 0;
                            int absent = 0;
                        }

                        @foreach (var day in new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday" })
                        {
                            <tr>
                                <td>@day</td>

                                @foreach (var slot in new[] { "9-10", "10-11", "11-12", "12-1", "L", "2-3", "3-4", "4-5" })
                                {
                                    if (slot == "L")
                                    {
                                        <td class="lunch">Lunch</td>
                                    }
                                    else
                                    {
                                        var item = Model.FirstOrDefault(x => x.DayOfWeek == day && x.Slot == slot);

                                        if (item == null)
                                        {
                                            <td>-</td>
                                        }
                                        else
                                        {
                                            string cls = "pending";

                                            if (item.IsPresent == 1) { cls = "present"; present++; }
                                            else if (item.IsPresent == 0) { cls = "absent"; absent++; }

                                            <td class="@cls">
                                                @item.SubjectName
                                                <br />
                                                <small>@item.Teacher</small>
                                            </td>
                                        }
                                    }
                                }
                            </tr>
                        }

                    </tbody>
                </table>

            </div>
        </div>

        <div class="col-md-4">
            <div class="main-card p-3">
                <h5 class="mb-3" style="color:white">Attendance</h5>

                <div class="chart-container">
                    <canvas id="pieChart"></canvas>
                </div>

            </div>
        </div>

    </div>
</div>

<script>
var present=@present;
var absent=@absent;
var total=present+absent;

document.getElementById("percent").innerText =
(total==0?0:Math.round(present*100/total))+"%";

new Chart(document.getElementById("pieChart"),{
type:"doughnut",
data:{
labels:["Present","Absent"],
datasets:[{
data:[present,absent],
backgroundColor:["#22c55e","#ef4444"],
borderWidth:0
}]
},
options:{
cutout:"70%",
maintainAspectRatio:true
}
});
</script>