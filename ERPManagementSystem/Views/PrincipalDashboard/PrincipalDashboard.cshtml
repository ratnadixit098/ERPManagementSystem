@model ERPManagementSystem.Models.PrincipalDashboard
@{
  //  Layout = "~/Views/Shared/PrincipalLayout.cshtml";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>

<style>
    body {
        background: #0b0f19;
        color: #fff;
    }

    .card-box {
        cursor: pointer;
        background: rgba(17,24,39,.7);
        border-radius: 12px;
        padding: 20px;
        transition: .3s;
        border: 1px solid rgba(255,255,255,.05);
    }

        .card-box:hover {
            transform: translateY(-3px);
            box-shadow: 0 0 15px rgba(59,130,246,.4);
        }

    .title {
        background: linear-gradient(90deg,#60a5fa,#34d399,#fbbf24,#f87171);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .count {
        font-size: 26px;
        font-weight: 700;
        text-shadow: 0 0 8px rgba(59,130,246,.7);
    }

    .chart-card {
        background: rgba(17,24,39,.7);
        border-radius: 12px;
        padding: 15px;
        height: 420px;
    }

    .chart-container {
        height: 320px;
    }

    .report-box {
        display: none;
        background: #111827;
        border-radius: 10px;
        padding: 15px;
        margin-top: 15px;
    }

    .close-btn {
        float: right;
        cursor: pointer;
        color: #f87171;
        font-weight: bold;
    }
</style>

<div class="container-fluid mt-4">

    <div class="row g-3">

        <div class="col-md-3">
            <div class="card-box" onclick="toggleReport('deptReport')">
                <div class="title">Departments</div>
                <div class="count">@Model.TotalDepartments</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card-box" onclick="toggleReport('courseReport')">
                <div class="title">Courses</div>
                <div class="count">@Model.TotalCourses</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card-box" onclick="toggleReport('teacherReport')">
                <div class="title">Teachers</div>
                <div class="count">@Model.TotalTeachers</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="card-box" onclick="toggleReport('studentReport')">
                <div class="title">Students</div>
                <div class="count">@Model.TotalStudents</div>
            </div>
        </div>

    </div>

    <!-- Reports -->
    <div id="deptReport" class="report-box">
        <span class="close-btn" onclick="toggleReport('deptReport')">X</span>
        <h5>Department Report</h5>
        <table class="table table-dark table-bordered">
            @foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.DepartmentList).Rows)
            {
                <tr><td>@row[0]</td><td>@row[1]</td></tr>
            }
        </table>
    </div>

    <div id="courseReport" class="report-box">
        <span class="close-btn" onclick="toggleReport('courseReport')">X</span>
        <h5>Course Report</h5>
        <table class="table table-dark table-bordered">
            @foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.CourseList).Rows)
            {
                <tr><td>@row[0]</td><td>@row[1]</td></tr>
            }
        </table>
    </div>

    <div id="teacherReport" class="report-box">
        <span class="close-btn" onclick="toggleReport('teacherReport')">X</span>
        <h5>Teacher Report</h5>
        <table class="table table-dark table-bordered">
            @foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.TeacherList).Rows)
            {
                <tr><td>@row[0]</td><td>@row[1]</td></tr>
            }
        </table>
    </div>

    <div id="studentReport" class="report-box">
        <span class="close-btn" onclick="toggleReport('studentReport')">X</span>
        <h5>Student Report</h5>
        <table class="table table-dark table-bordered">
            @foreach (System.Data.DataRow row in ((System.Data.DataTable)ViewBag.StudentList).Rows)
            {
                <tr><td>@row[0]</td><td>@row[1]</td></tr>
            }
        </table>
    </div>

    <div class="row mt-4">

        <div class="col-md-6">
            <div class="chart-card">
                <h5 class="title">Students vs Teachers</h5>
                <div class="chart-container">
                    <canvas id="pieChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="chart-card">
                <h5 class="title">Department Wise Students</h5>
                <div class="chart-container">
                    <canvas id="barChart"></canvas>
                </div>
            </div>
        </div>

    </div>

</div>

<script>
function toggleReport(id){
$("#"+id).slideToggle();
}

var students=@Model.TotalStudents;
var teachers=@Model.TotalTeachers;

var ctx=document.getElementById("pieChart").getContext("2d");

var gradient1=ctx.createLinearGradient(0,0,0,400);
gradient1.addColorStop(0,"#3b82f6");
gradient1.addColorStop(1,"#06b6d4");

var gradient2=ctx.createLinearGradient(0,0,0,400);
gradient2.addColorStop(0,"#22c55e");
gradient2.addColorStop(1,"#4ade80");

new Chart(ctx,{
type:"doughnut",
data:{
labels:["Students","Teachers"],
datasets:[{
data:[students,teachers],
backgroundColor:[gradient1,gradient2]
}]
},
options:{cutout:"65%"}
});

var deptNames=@Html.Raw(Json.Encode(ViewBag.DeptNames));
var deptStudents=@Html.Raw(Json.Encode(ViewBag.DeptStudents));

new Chart(document.getElementById("barChart"),{
type:"bar",
data:{
labels:deptNames,
datasets:[{
data:deptStudents,
backgroundColor:"#f59e0b",
maxBarThickness:60
}]
},
options:{
responsive:true,
maintainAspectRatio:false,
plugins:{legend:{display:false}},
scales:{y:{beginAtZero:true}}
}
});
</script>