@model ERPManagementSystem.Models.FeesCommitment

@{
    Layout = "~/Views/Shared/Principal.cshtml";
}

<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />

<style>
    .card {
        border-radius: 12px;
        border: none;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        background: #0c1327;
    }

    .card-header {
        background: #0c1327;
        color: white;
        border-radius: 12px 12px 0 0 !important;
        font-weight: bold;
    }

    .form-label {
        font-weight: 600;
        color: white;
        margin-top: 10px;
    }

    .form-control:focus {
        border-color: #4e73df;
        box-shadow: 0 0 0 0.2rem rgba(78, 115, 223, 0.25);
    }

    .btn-save {
        background: #1cc88a;
        border: none;
        padding: 10px 25px;
        font-weight: bold;
        transition: 0.3s;
        color: white;
    }

        .btn-save:hover {
            background: #17a673;
            transform: translateY(-2px);
            color: white;
        }

    .btn-add {
        border-radius: 50px;
        font-size: 14px;
    }

    .table-container {
        background: #f8f9fc;
        padding: 15px;
        border-radius: 10px;
        margin-top: 20px;
    }

    .btn-remove {
        color: #e74a3b;
        cursor: pointer;
        border: none;
        background: none;
    }
</style>

<div class="">
    <div class="card">
        <div class="card-header d-flex align-items-center border-dark p-4">
            <i class="fas fa-file-invoice-dollar me-2"></i>
            <h4 class="mb-0">Fee Commitment Form</h4>
        </div>
        <div class="card-body p-4">

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <strong>Success!</strong> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @using (Html.BeginForm())
            {
                <div class="row">
                    <div class="col-md-6">
                        <h5 class="text-primary mb-3"><i class="fas fa-university me-2"></i>Academic Details</h5>

                        <div class="mb-3">
                            <label class="form-label">College</label>
                            @Html.DropDownList("CollegeId", (IEnumerable<SelectListItem>)ViewBag.CollegeList, "Select College", new { @class = "form-select", id = "CollegeId" })
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Department</label>
                            <select id="DepartmentId" class="form-select"><option>Select Department</option></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Course</label>
                            <select id="CourseId" class="form-select"><option>Select Course</option></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Class</label>
                            <select id="ClassId" class="form-select"><option>Select Class</option></select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Student</label>
                            @Html.DropDownListFor(m => m.StudentId, new List<SelectListItem>(), "Select Student", new { @class = "form-select", id = "StudentId" })
                        </div>
                    </div>

                    <div class="col-md-6">
                        <h5 class="text-primary mb-3"><i class="fas fa-money-bill-wave me-2"></i>Payment Details</h5>

                        <div class="mb-3">
                            <label class="form-label">Total Fees</label>
                            <div class="input-group">
                                <span class="input-group-text">₹</span>
                                @Html.TextBoxFor(m => m.TotalFees, new { @class = "form-control", placeholder = "0.00" })
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Fee Type</label>
                            @Html.DropDownListFor(m => m.FeeType,
                            new List<SelectListItem>
                            {
                                new SelectListItem{Text="One Time Payment",Value="OnTime"},
                                new SelectListItem{Text="Installment Basis",Value="Installment"}
                            },
                            "Select Payment Type",
                            new { @class = "form-select", id = "FeeType" })
                        </div>

                        <div id="installmentDiv" style="display:none" class="table-container">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <h6 class="mb-0 fw-bold text-secondary">Installment Schedule</h6>
                                <button type="button" onclick="addRow()" class="btn btn-sm btn-outline-primary btn-add">
                                    <i class="fas fa-plus"></i> Add Installment
                                </button>
                            </div>
                            <table class="table table-sm table-hover align-middle">
                                <thead class="table-light">
                                    <tr>
                                        <th>Date</th>
                                        <th>Amount</th>
                                        <th width="40px"></th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <hr class="my-4" />

                <div class="text-end">
                    <button type="reset" class="btn btn-light me-2">Clear Form</button>
                    <button type="submit" class="btn btn-save">
                        <i class="fas fa-check-circle me-1"></i> Save Commitment
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<script src="~/Scripts/jquery-3.7.0.min.js"></script>
<script>
    // Toggle Installment Div
    $("#FeeType").change(function () {
        if ($(this).val() == "Installment") {
            $("#installmentDiv").fadeIn();
            if ($("table tbody tr").length === 0) addRow(); // Auto-add first row
        } else {
            $("#installmentDiv").fadeOut();
        }
    });

    function addRow() {
        var row = `<tr>
            <td><input type="date" name="InstallmentDate" class="form-control form-control-sm"/></td>
            <td><input type="number" name="InstallmentAmount" class="form-control form-control-sm" placeholder="Amount"/></td>
            <td class="text-center"><button type="button" onclick="removeRow(this)" class="btn-remove"><i class="fas fa-times-circle"></i></button></td>
        </tr>`;
        $("table tbody").append(row);
    }

    function removeRow(btn) {
        $(btn).closest("tr").fadeOut(300, function () { $(this).remove(); });
    }

    // Cascading AJAX (Aapka existing logic)
    function setupCascade(triggerId, targetId, url, paramName, placeholder) {
        $("#" + triggerId).change(function () {
            var val = $(this).val();
            var target = $("#" + targetId);
            target.empty().append('<option value="">Loading...</option>');

            $.get(url, { [paramName]: val }, function (data) {
                target.empty().append('<option value="">' + placeholder + '</option>');
                $.each(data, function (i, row) {
                    // Logic for mapping fields (DepartmentId/Name etc.)
                    var idField = Object.keys(row)[0];
                    var textField = Object.keys(row)[1];
                    target.append("<option value='" + row[idField] + "'>" + (row[textField] || row['Section']) + "</option>");
                });
            });
        });
    }

    // Initialize cascading
    setupCascade("CollegeId", "DepartmentId", "/Commitment/GetDepartment", "collegeId", "Select Department");
    setupCascade("DepartmentId", "CourseId", "/Commitment/GetCourse", "departmentId", "Select Course");
    setupCascade("CourseId", "ClassId", "/Commitment/GetClass", "courseId", "Select Class");
    setupCascade("ClassId", "StudentId", "/Commitment/GetStudent", "classId", "Select Student");
</script>