@model ERPManagementSystem.Models.FeesCommitment

@{
    Layout = "~/Views/Shared/TeacherLayout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background-color: #020617 !important;
        color: #f1f5f9 !important;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }


    /* 💎 Main Form Card */
    .form-card {
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        margin-bottom: 30px;
    }

    .form-header {
        background: rgba(255, 255, 255, 0.02);
        padding: 25px 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-icon {
        width: 45px;
        height: 45px;
        background: linear-gradient(135deg, #6366f1, #a855f7);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-size: 18px;
        box-shadow: 0 0 15px rgba(99, 102, 241, 0.4);
    }

    .form-header h4 {
        margin: 0;
        font-weight: 700;
        background: linear-gradient(to right, #fff, #94a3b8);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ⚡ Form Styling */
    label {
        font-size: 13px;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 8px;
        margin-top: 15px;
        display: block;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .form-control, .form-select {
        background: rgba(2, 6, 23, 0.6) !important;
        border: 1px solid #334155 !important;
        color: #f1f5f9 !important;
        border-radius: 12px;
        padding: 12px 15px;
    }

        .form-control:focus, .form-select:focus {
            border-color: #6366f1 !important;
            box-shadow: 0 0 0 4px rgba(99, 102, 241, 0.1) !important;
        }

    /* 🗓️ Installment Section */
    #installmentDiv {
        background: rgba(255, 255, 255, 0.02);
        border-radius: 16px;
        border: 1px dashed rgba(99, 102, 241, 0.3);
        padding: 25px;
        margin-top: 25px;
    }

    .table {
        color: #f1f5f9;
        margin-top: 15px;
    }

        .table th {
            border-bottom: 1px solid #334155;
            color: #6366f1;
            font-size: 14px;
            text-transform: uppercase;
        }

        .table td {
            border-bottom: 1px solid rgba(255,255,255,0.05);
            vertical-align: middle;
            padding: 12px;
        }

    /* 🚀 Buttons */
    .btn-add {
        background: rgba(99, 102, 241, 0.1);
        color: #818cf8;
        border: 1px solid rgba(99, 102, 241, 0.2);
        border-radius: 8px;
        font-weight: 600;
        padding: 8px 18px;
        transition: 0.3s;
    }

        .btn-add:hover {
            background: #6366f1;
            color: white;
        }

    .btn-remove {
        background: rgba(239, 68, 68, 0.1);
        color: #ef4444;
        border: none;
        border-radius: 8px;
        width: 32px;
        height: 32px;
        transition: 0.2s;
    }

        .btn-remove:hover {
            background: #ef4444;
            color: white;
        }

    .btn-save {
        background: linear-gradient(135deg, #10b981, #059669);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px 30px;
        font-weight: 700;
        width: 100%;
        box-shadow: 0 10px 20px rgba(16, 185, 129, 0.2);
        transition: 0.3s;
    }

        .btn-save:hover {
            transform: translateY(-2px);
            filter: brightness(1.1);
        }
</style>

<div class="container container-main">
    <div class="card form-card">
        <div class="form-header">
            <div class="header-icon"><i class="fa fa-handshake"></i></div>
            <div>
                <h4>Fee Commitment Entry</h4>
                <small class="text-muted">Manage academic filters and payment schedules</small>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success bg-success bg-opacity-10 border-success border-opacity-25 text-success mb-4 rounded-4 px-4 py-3">
                    <i class="fa fa-check-circle me-2"></i> @TempData["Success"]
                </div>
            }

            @using (Html.BeginForm())
            {
                <div class="row g-4">
                    <div class="col-md-6 border-end border-white border-opacity-5 pe-md-4">
                        <label><i class="fa fa-building text-primary me-2"></i>College</label>
                        @Html.DropDownList("CollegeId", (IEnumerable<SelectListItem>)ViewBag.CollegeList, "-Select College-", new { @class = "form-select", id = "CollegeId" })

                        <label><i class="fa fa-sitemap text-primary me-2"></i>Department</label>
                        <select id="DepartmentId" class="form-select"><option>-Select-</option></select>

                        <label><i class="fa fa-graduation-cap text-primary me-2"></i>Course</label>
                        <select id="CourseId" class="form-select"><option>-Select-</option></select>

                        <label><i class="fa fa-chalkboard-user text-primary me-2"></i>Class</label>
                        <select id="ClassId" class="form-select"><option>-Select-</option></select>

                        <label><i class="fa fa-user-graduate text-primary me-2"></i>Student</label>
                        @Html.DropDownListFor(m => m.StudentId, new List<SelectListItem>(), "-Select-", new { @class = "form-select", id = "StudentId" })
                    </div>

                    <div class="col-md-6 ps-md-4">
                        <label><i class="fa fa-indian-rupee-sign text-primary me-2"></i>Total Committed Fees</label>
                        @Html.TextBoxFor(m => m.TotalFees, new { @class = "form-control", placeholder = "0.00" })

                        <label><i class="fa fa-calendar-day text-primary me-2"></i>Payment Type</label>
                        @Html.DropDownListFor(m => m.FeeType,
                        new List<SelectListItem>
                        {
                            new SelectListItem{Text="Full One-Time Payment",Value="OnTime"},
                            new SelectListItem{Text="Installment Plan",Value="Installment"}
                        }, "Choose Plan", new { @class = "form-select", id = "FeeType" })

                        <div id="installmentDiv">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h6 class="m-0 text-info fw-bold small">Schedule Installments</h6>
                                <button type="button" onclick="addRow()" class="btn btn-add btn-sm">
                                    <i class="fa fa-plus me-1"></i> Add Date
                                </button>
                            </div>
                            <div class="table-responsive">
                                <table class="table table-borderless">
                                    <thead>
                                        <tr>
                                            <th>Date</th>
                                            <th>Amount</th>
                                            <th width="40"></th>
                                        </tr>
                                    </thead>
                                    <tbody></tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="mt-5 pt-3 border-top border-white border-opacity-5">
                    <button type="submit" class="btn btn-save">
                        <i class="fa fa-save me-2"></i> Finalize Commitment
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<script>
    // Toggle Installment Div
    $("#FeeType").change(function () {
        if ($(this).val() == "Installment")
            $("#installmentDiv").fadeIn();
        else {
            $("#installmentDiv").fadeOut();
            $("table tbody").empty();
        }
    });

    function addRow() {
        var row = `<tr class="animate__animated animate__fadeIn">
            <td><input type="date" name="InstallmentDate" class="form-control form-control-sm"/></td>
            <td><input type="text" name="InstallmentAmount" class="form-control form-control-sm" placeholder="₹ 0.00"/></td>
            <td class="text-center"><button type="button" onclick="removeRow(this)" class="btn-remove"><i class="fa fa-trash-alt"></i></button></td>
        </tr>`;
        $("table tbody").append(row);
    }

    function removeRow(btn) {
        $(btn).closest("tr").fadeOut(200, function () { $(this).remove(); });
    }

    // Cascading Dropdowns Logic
    $("#CollegeId").change(function () {
        $.get("/Commitment/GetDepartment", { collegeId: $(this).val() }, function (data) {
            $("#DepartmentId").empty().append("<option value=''>-Select-</option>");
            $.each(data, function (i, row) {
                $("#DepartmentId").append("<option value='" + row.DepartmentId + "'>" + row.DepartmentName + "</option>");
            });
        });
    });

    $("#DepartmentId").change(function () {
        $.get("/Commitment/GetCourse", { departmentId: $(this).