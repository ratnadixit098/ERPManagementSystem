@model ERPManagementSystem.Models.College

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    body {
        background: #f5f7fb;
    }
    body {
        background: #f5f7fb;
        background-image: url('/content/images/OIP (1).jfif');
        background-repeat: no-repeat;
        background-size: cover;
    }

    .form-card {
        border-radius: 18px;
        border: none;
        max-width: 800px;
        margin: auto;
    }

    .form-header {
        background: linear-gradient(135deg,#4e73df,#224abe);
        color: white;
        border-radius: 18px 18px 0 0;
        padding: 18px 25px;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 10px;
    }

    label {
        font-weight: 600;
        margin-bottom: 5px;
    }

    .btn-save {
        border-radius: 10px;
        padding: 10px 25px;
    }

    .field-validation-error {
        color: red;
        font-size: 13px;
    }
</style>

@if (TempData["Success"] != null)
{<div class="container mt-3" style="max-width:800px;">
        <div class="alert alert-success alert-dismissible fade show">
            @TempData["Success"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    </div>
}

<div class="container mt-4">
    <div class="card shadow-lg form-card">

        ```
        <div class="form-header">
            <h4 class="mb-0">
                <i class="fa fa-building"></i> College Master Entry
            </h4>
        </div>

        <div class="card-body p-4">

            @using (Html.BeginForm())
            {
                <div class="row g-3">

                    <div class="col-sm-6">
                        <label>College Code</label>
                        @Html.TextBoxFor(x => x.CollegeCode, new { @class = "form-control", required = "required" })
                        @Html.ValidationMessageFor(x => x.CollegeCode)
                    </div>

                    <div class="col-sm-6">
                        <label>College Name</label>
                        @Html.TextBoxFor(x => x.CollegeName, new { @class = "form-control", required = "required" })
                        @Html.ValidationMessageFor(x => x.CollegeName)
                    </div>

                    <div class="col-sm-6">
                        <label>State</label>
                        @Html.DropDownListFor(x => x.StateId,
                            ViewBag.StateList as IEnumerable<SelectListItem>,
                            "Select State",
                            new { @class = "form-select", id = "ddlState", required = "required" })
                        @Html.ValidationMessageFor(x => x.StateId)
                    </div>

                    <div class="col-sm-6">
                        <label>District</label>
                        @Html.DropDownListFor(x => x.DistrictId,
                            new List<SelectListItem>(),
                            "Select District",
                            new { @class = "form-select", id = "ddlDistrict", required = "required" })
                        @Html.ValidationMessageFor(x => x.DistrictId)
                    </div>

                    <div class="col-sm-6">
                        <label>Phone Number</label>
                        @Html.TextBoxFor(x => x.PhoneNumber, new
                        {
                            @class = "form-control",
                            required = "required",
                            pattern = "[0-9]{10}",
                            maxlength = "10",
                            placeholder = "10 digit mobile number"
                        })
                        @Html.ValidationMessageFor(x => x.PhoneNumber)
                    </div>

                    <div class="col-sm-6">
                        <label>Email</label>
                        @Html.TextBoxFor(x => x.Email, new
                        {
                            @class = "form-control",
                            type = "email",
                            required = "required"
                        })
                        @Html.ValidationMessageFor(x => x.Email)
                    </div>

                    <div class="col-sm-12">
                        <label>Address</label>
                        @Html.TextAreaFor(x => x.Address, new
                        {
                            @class = "form-control",
                            rows = "2",
                            required = "required"
                        })
                        @Html.ValidationMessageFor(x => x.Address)
                    </div>

                </div>

                <div class="text-end mt-4">
                    <button type="submit" class="btn btn-success btn-save">
                        <i class="fa fa-save"></i> Save College
                    </button>
                </div>
            }

        </div>
    </div>
    ```

</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<script>
    $(document).ready(function () {

        $("#ddlState").change(function () {

            var stateId = $(this).val();

            $.get("/College/GetDistrict", { StateId: stateId }, function (data) {

                $("#ddlDistrict").empty();
                $("#ddlDistrict").append("<option value=''>Select District</option>");

                $.each(data, function (i, item) {
                    $("#ddlDistrict").append("<option value='" + item.DistrictId + "'>" + item.DistrictName + "</option>");
                });

            });

        });

    });
</script>
