@model ERPManagementSystem.Models.Teacher

@{
    Layout = "~/Views/Shared/Principal.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" rel="stylesheet" />

<style>
    /* ✨ Core Theme Reset */
    body {
        background-color: #020617 !important;
        color: #f1f5f9 !important;
        font-family: 'Plus Jakarta Sans', sans-serif;
    }


    /* 💎 Glassmorphism Card */
    .form-card {
        background: rgba(15, 23, 42, 0.8);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 24px;
        box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
        max-width: 900px;
        margin: auto;
        overflow: hidden;
    }

    /* 🎨 Header with Crimson Gradient */
    .form-header {
        background: rgba(255, 255, 255, 0.02);
        padding: 25px 30px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        display: flex;
        align-items: center;
        gap: 15px;
    }

    .header-icon {
        width: 48px;
        height: 48px;
        background: linear-gradient(135deg, #f43f5e, #9f1239);
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
        color: white;
        box-shadow: 0 0 20px rgba(244, 63, 94, 0.4);
    }

    .form-header h4 {
        margin: 0;
        font-weight: 700;
        letter-spacing: -0.5px;
        background: linear-gradient(to right, #fff, #fb7185);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    /* ⚡ Form Elements */
    label {
        font-size: 13px;
        font-weight: 600;
        color: #94a3b8;
        margin-bottom: 8px;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        display: block;
    }

    .form-control, .form-select {
        background: rgba(2, 6, 23, 0.6) !important;
        border: 1px solid #334155 !important;
        color: #f1f5f9 !important;
        border-radius: 12px;
        padding: 12px 16px;
        transition: all 0.3s ease;
    }

        .form-control:focus, .form-select:focus {
            border-color: #f43f5e !important;
            box-shadow: 0 0 0 4px rgba(244, 63, 94, 0.15) !important;
            background: rgba(2, 6, 23, 0.8) !important;
        }

    /* 🚀 Action Button */
    .btn-save {
        background: linear-gradient(135deg, #f43f5e, #e11d48);
        color: white;
        border: none;
        border-radius: 12px;
        padding: 14px 32px;
        font-weight: 700;
        transition: 0.3s;
        box-shadow: 0 10px 15px -3px rgba(244, 63, 94, 0.3);
    }

        .btn-save:hover {
            transform: translateY(-2px);
            box-shadow: 0 20px 25px -5px rgba(244, 63, 94, 0.4);
            filter: brightness(1.1);
        }

    /* ✅ Modern Alert */
    .alert-modern {
        background: rgba(16, 185, 129, 0.1);
        border: 1px solid rgba(16, 185, 129, 0.2);
        color: #34d399;
        border-radius: 16px;
        padding: 15px 25px;
        margin-bottom: 25px;
        text-align: center;
    }
</style>

<div class="container container-main">

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-modern d-flex align-items-center justify-content-center mx-auto" style="max-width:900px;">
            <i class="fa-solid fa-circle-check me-2"></i> @TempData["Success"]
        </div>
    }

    <div class="card form-card">
        <div class="form-header">
            <div class="header-icon">
                <i class="fa fa-user-tie"></i>
            </div>
            <div>
                <h4>Teacher Registration</h4>
                <small class="text-muted">Onboard new faculty members and staff</small>
            </div>
        </div>

        <div class="card-body p-4 p-lg-5">
            @using (Html.BeginForm())
            {
                <div class="row g-4">

                    <div class="col-md-6">
                        <label><i class="fa fa-building-user me-2 text-danger"></i>Department</label>
                        @Html.DropDownListFor(x => x.DepartmentId,
                            ViewBag.DepartmentList as IEnumerable<SelectListItem>,
                            "Select Department",
                            new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-briefcase me-2 text-danger"></i>Designation / Post</label>
                        @Html.DropDownListFor(x => x.Post_Id,
                            ViewBag.PostList as IEnumerable<SelectListItem>,
                            "Select Post",
                            new { @class = "form-select", required = "required" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-id-badge me-2 text-danger"></i>Teacher Employee Code</label>
                        @Html.TextBoxFor(x => x.TeacherCode, new { @class = "form-control", required = "required", placeholder = "EX: TCH-001" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-calendar-check me-2 text-danger"></i>Date of Joining</label>
                        @Html.TextBoxFor(x => x.JoiningDate, new { @class = "form-control", type = "date", required = "required" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-user me-2 text-danger"></i>First Name</label>
                        @Html.TextBoxFor(x => x.FirstName, new { @class = "form-control", required = "required", placeholder = "Enter first name" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-user me-2 text-danger"></i>Last Name</label>
                        @Html.TextBoxFor(x => x.LastName, new { @class = "form-control", required = "required", placeholder = "Enter last name" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-envelope me-2 text-danger"></i>Email Address</label>
                        @Html.TextBoxFor(x => x.Email, new { @class = "form-control", type = "email", required = "required", placeholder = "email@institution.com" })
                    </div>

                    <div class="col-md-6">
                        <label><i class="fa fa-phone me-2 text-danger"></i>Contact Number</label>
                        @Html.TextBoxFor(x => x.Phone, new { @class = "form-control", maxlength = "10", placeholder = "10 digit mobile number", required = "required" })
                    </div>

                </div>

                <div class="d-flex justify-content-end gap-3 mt-5 pt-3 border-top border-white border-opacity-10">
                    <button type="reset" class="btn btn-outline-secondary border-0 text-white-50 px-4">Reset Form</button>
                    <button type="submit" class="btn btn-save">
                        <i class="fa fa-save me-2"></i> Register Faculty
                    </button>
                </div>
            }
        </div>
    </div>
</div>